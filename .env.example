# Candelabrum Studio secrets. Copy to `.env` (gitignored) and fill in.
# Never commit `.env`. Non-secret configuration lives in `config/*.toml`.

# Director LLM — required for the direct stage. Default provider is Claude,
# read lazily by the Vercel AI SDK at request time.
ANTHROPIC_API_KEY=
DIRECTOR_MODEL=claude-3-5-sonnet-20240620

# Gemini is a config swap for the director (set `providers.director` in
# config/settings.toml accordingly, then provide this key instead):
# GOOGLE_GENERATIVE_AI_API_KEY=
# DIRECTOR_MODEL=gemini-1.5-pro

# Image / video stages default to the manual inbox (no key needed). Set these
# only when switching a stage to a paid API in config/settings.toml (later slices):
# FAL_KEY=
# REPLICATE_API_TOKEN=
# IMAGE_MODEL=flux-dev
# VIDEO_MODEL=kling-2.5-turbo
