# Candelabrum Studio secrets. Copy to `.env` (gitignored) and fill in.
# Never commit `.env`. Non-secret configuration lives in `config/*.toml`.

# Director LLM — required for the direct stage. Default provider is Claude,
# read lazily by the Vercel AI SDK at request time.
ANTHROPIC_API_KEY=
DIRECTOR_MODEL=claude-3-5-sonnet-20240620

# Image stage — Google "Nano Banana" Gemini image model by default
# (config/settings.toml: image = "gemini"). Uses your AI Studio key.
GEMINI_API_KEY=
# Active image model id. For "gemini": gemini-3.1-flash-image (or
# gemini-2.5-flash-image). For "fal": a fal id like fal-ai/flux/dev.
IMAGE_MODEL=gemini-3.1-flash-image

# Alternative image provider — FLUX on fal (config/settings.toml: image = "fal"):
# FAL_KEY=

# Video stage still defaults to the manual inbox (no key needed). Set these only
# when switching it to a paid API in config/settings.toml:
# REPLICATE_API_TOKEN=
# VIDEO_MODEL=kling-2.5-turbo
